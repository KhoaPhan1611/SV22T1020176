@model SV22T1020176.Models.Partner.Customer
@{
    ViewData["Title"] = "Thanh toán đơn hàng";
    var cart = ViewBag.Cart as List<SV22T1020176.Shop.Models.CartItem> ?? new List<SV22T1020176.Shop.Models.CartItem>();
    var total = cart.Sum(c => c.TotalPrice);
}

<div class="animate-in">
    <!-- Page Header -->
    <div class="d-flex align-items-center justify-content-between mb-5 border-bottom pb-4">
        <div>
            <h1 class="fw-800 text-dark display-6 mb-1">Thanh toán</h1>
            <p class="text-muted fw-500 mb-0 px-1">Vui lòng cung cấp thông tin để hoàn tất đơn hàng</p>
        </div>
        <a href="~/Cart" class="btn btn-outline-secondary rounded-pill px-4 fw-600 fs-7 shadow-sm">
            <i class="bi bi-chevron-left"></i> Quay lại giỏ hàng
        </a>
    </div>

    <form id="checkoutForm" action="~/Cart/ProcessOrder" method="post" class="row g-5">
        <!-- Left: Shipping & Method -->
        <div class="col-lg-7 d-flex flex-column gap-5">

            <!-- 1. Shipping Address -->
            <div class="card border-0 shadow-sm rounded-4 scroll-mt">
                <div class="card-header bg-white border-0 py-4 px-4 d-flex align-items-center gap-3">
                    <span class="bg-primary text-white d-inline-flex align-items-center justify-content-center rounded-circle fw-800 shadow-sm" style="width:32px; height:32px;">1</span>
                    <h5 class="fw-bold mb-0 text-dark">Thông tin nhận hàng</h5>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="row g-4 mb-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label fs-7 fw-600 text-dark ps-1 mb-2">Người nhận <span class="text-danger">*</span></label>
                                <input type="text" name="recipientName" value="@Model.CustomerName" required 
                                       class="form-control border-0 bg-light rounded-3 py-2 ps-3 shadow-none fw-600" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label fs-7 fw-600 text-dark ps-1 mb-2">Số điện thoại <span class="text-danger">*</span></label>
                                <input type="tel" name="recipientPhone" value="@Model.Phone" required 
                                       class="form-control border-0 bg-light rounded-3 py-2 ps-3 shadow-none fw-600" />
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-group">
                                <label class="form-label fs-7 fw-600 text-dark ps-1 mb-2">Địa chỉ cụ thể <span class="text-danger">*</span></label>
                                <input type="text" name="deliveryAddress" value="@Model.Address" required 
                                       class="form-control border-0 bg-light rounded-3 py-2 ps-3 shadow-none" placeholder="Số nhà, đường, phường/xã..." />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label fs-7 fw-600 text-dark ps-1 mb-2">Tỉnh / Thành phố <span class="text-danger">*</span></label>
                                <select name="deliveryProvince" required class="form-select border-0 bg-light rounded-3 py-2 ps-3 shadow-none fs-7 fw-600">
                                    <option value="">-- Chọn Tỉnh/Thành --</option>
                                    @foreach (var p in await SV22T1020176.BusinessLayers.DictionaryDataService.ListProvincesAsync())
                                    {
                                        <option value="@p.ProvinceName" selected="@(p.ProvinceName == Model.Province)">@p.ProvinceName</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 2. Shipping Method -->
            <div class="card border-0 shadow-sm rounded-4 scroll-mt">
                <div class="card-header bg-white border-0 py-4 px-4 d-flex align-items-center gap-3">
                    <span class="bg-primary text-white d-inline-flex align-items-center justify-content-center rounded-circle fw-800 shadow-sm" style="width:32px; height:32px;">2</span>
                    <h5 class="fw-bold mb-0 text-dark">Đơn vị vận chuyển</h5>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="d-flex flex-column gap-3">
                        @{
                            var shippers = (ViewBag.Shippers as PagedResult<Shipper>)?.DataItems ?? new List<Shipper>();
                            if (shippers.Count == 0)
                            {
                                <div class="p-3 border rounded-4 d-flex align-items-center gap-3 bg-light">
                                    <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center" style="width:40px; height:40px;">
                                        <i class="bi bi-truck fs-5"></i>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-0">Miễn phí vận chuyển</h6>
                                        <span class="fs-8 text-muted">Mặc định cho mọi đơn hàng</span>
                                    </div>
                                    <input type="hidden" name="ShipperID" value="0" />
                                </div>
                            }
                            else
                            {
                                var first = true;
                                @foreach (var s in shippers)
                                {
                                    <label class="shipper-selection p-3 border rounded-4 d-flex align-items-center gap-3 cursor-pointer transition-all @(first ? "active" : "")">
                                        <div class="form-check m-0">
                                            <input class="form-check-input shadow-none" type="radio" name="shipperID" value="@s.ShipperID" required @(first ? "checked" : "") onclick="updateShipperSelection(this)" />
                                        </div>
                                        <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center" style="width:40px; height:40px;">
                                            <i class="bi bi-truck fs-5"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <h6 class="fw-bold mb-0">@s.ShipperName</h6>
                                            <span class="fs-8 text-muted">@s.Phone</span>
                                        </div>
                                        <span class="badge bg-success-subtle text-success fw-bold p-2 px-3 rounded-pill uppercase fs-9">Miễn phí</span>
                                    </label>
                                    first = false;
                                }
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- 3. Payment Method -->
            <div class="card border-0 shadow-sm rounded-4 scroll-mt">
                <div class="card-header bg-white border-0 py-4 px-4 d-flex align-items-center gap-3">
                    <span class="bg-primary text-white d-inline-flex align-items-center justify-content-center rounded-circle fw-800 shadow-sm" style="width:32px; height:32px;">3</span>
                    <h5 class="fw-bold mb-0 text-dark">Phương thức thanh toán</h5>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="p-4 border border-primary border-opacity-25 bg-primary bg-opacity-5 rounded-4 d-flex align-items-center gap-4">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width:48px; height:48px;">
                            <i class="bi bi-cash-coin fs-4"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h6 class="fw-bold mb-1 text-dark">Thanh toán khi nhận hàng (COD)</h6>
                            <p class="fs-8 text-muted mb-0">Kiểm tra sản phẩm và thanh toán cho shipper khi nhận hàng thành công.</p>
                        </div>
                        <i class="bi bi-check-circle-fill fs-3 text-primary"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Order Review -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 p-4 sticky-top" style="top: 100px;">
                <div class="d-flex align-items-center gap-3 mb-4 pb-3 border-bottom">
                    <i class="bi bi-bag-check-fill text-primary fs-3"></i>
                    <h5 class="fw-bold mb-0 text-dark">Tóm tắt đơn hàng</h5>
                </div>

                <!-- Product Preview List -->
                <div class="d-flex flex-column gap-3 mb-4 scrollbar-thin" style="max-height: 300px; overflow-y: auto;">
                    @foreach (var item in cart)
                    {
                        <div class="d-flex align-items-center gap-3 pe-3">
                            <div class="bg-light rounded-3 overflow-hidden border border-opacity-10 p-1" style="width:56px; height:56px; flex-shrink:0;">
                                <img src="@(string.IsNullOrEmpty(item.Photo) ? "https://placehold.co/100x100/fff7ed/f97316?text=NP" : (item.Photo.StartsWith("http") ? item.Photo : $"/images/products/{item.Photo}"))"
                                     class="w-100 h-100 object-fit-cover rounded-2" />
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="fs-7 fw-bold mb-1 text-dark text-truncate" style="max-width: 180px;">@item.ProductName</h6>
                                <div class="fs-8 text-muted fw-600">
                                    <span>SL: @item.Quantity</span> <span class="mx-1">&times;</span> <span>@item.Price.ToString("N0")<small>đ</small></span>
                                </div>
                            </div>
                            <div class="fs-7 fw-bold text-dark text-end">@item.TotalPrice.ToString("N0")<small>đ</small></div>
                        </div>
                    }
                </div>

                <div class="d-flex flex-column gap-3 mb-4 pb-4 border-bottom">
                    <div class="d-flex justify-content-between fs-7 text-muted">
                        <span>Giá trị đơn hàng</span>
                        <span class="text-dark fw-bold">@total.ToString("N0") đ</span>
                    </div>
                    <div class="d-flex justify-content-between fs-7 text-muted">
                        <span>Phí vận chuyển</span>
                        <span class="text-success fw-bold">Miễn phí</span>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <span class="fw-bold text-dark fs-6">Tổng thanh toán:</span>
                    <h3 class="fw-900 text-primary mb-0">@total.ToString("N0")<small class="fs-6 fw-bold ms-1">đ</small></h3>
                </div>

                <!-- Note -->
                <div class="form-group mb-4">
                    <label class="form-label fs-8 fw-700 text-muted ps-1 mb-2 uppercase tracking-wider">Ghi chú đơn hàng (nếu có)</label>
                    <textarea name="note" rows="3" class="form-control border-0 bg-light rounded-4 p-3 shadow-none fs-7" 
                              style="resize:none;" placeholder="Yêu cầu đặc biệt cho shipper hoặc cửa hàng..."></textarea>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold fs-6 shadow-sm">
                    <i class="bi bi-shield-lock-fill me-2"></i> XÁC NHẬN ĐẶT HÀNG
                </button>
                
                <p class="text-center text-muted fs-9 mt-4 px-3 mb-0">
                    Bằng việc nhấp vào nút trên, bạn đồng ý với <strong>Điều khoản dịch vụ</strong> và <strong>Chính sách bảo mật</strong> của chúng tôi.
                </p>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function updateShipperSelection(input) {
            document.querySelectorAll('.shipper-selection').forEach(label => {
                label.classList.remove('active', 'border-primary', 'bg-primary', 'bg-opacity-5');
            });
            if (input.checked) {
                const label = input.closest('.shipper-selection');
                label.classList.add('active', 'border-primary', 'bg-primary', 'bg-opacity-5');
            }
        }
    </script>
}

<style>
    .shipper-selection:hover { background-color: #f8fafc; border-color: #e2e8f0; }
    .shipper-selection.active { border-color: var(--cui-primary) !important; background-color: rgba(249, 115, 22, 0.05) !important; }
    .cursor-pointer { cursor: pointer; }
    .transition-all { transition: all 0.2s ease; }
    .fw-800 { font-weight: 800; }
    .fw-900 { font-weight: 900; }
    .fs-7 { font-size: 0.875rem; }
    .fs-8 { font-size: 0.75rem; }
    .fs-9 { font-size: 0.65rem; }
    .uppercase { text-transform: uppercase; }
    .tracking-wider { letter-spacing: 0.05em; }
    .object-fit-cover { object-fit: cover; }
    .scroll-mt { scroll-margin-top: 120px; }
    .scrollbar-thin::-webkit-scrollbar { width: 4px; }
    .scrollbar-thin::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
</style>
