@model List<SV22T1020176.Shop.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng của bạn";
    var total = Model.Sum(c => c.TotalPrice);
}

<div class="animate-in">
    <!-- Page Header -->
    <div class="d-flex align-items-end justify-content-between mb-5 border-bottom pb-4">
        <div>
            <h1 class="fw-800 text-dark display-6 mb-1">Giỏ hàng</h1>
            <p class="text-muted fw-500 mb-0">Bạn đang có <span class="text-primary fw-bold">@Model.Sum(c => c.Quantity)</span> sản phẩm trong giỏ</p>
        </div>
        <a href="/" class="btn btn-link text-decoration-none text-muted fw-600 fs-7 px-0">
            <i class="bi bi-arrow-left"></i> Tiếp tục mua sắm
        </a>
    </div>

    @if (Model.Count == 0)
    {
        <!-- Empty State -->
        <div class="text-center py-5">
            <div class="mb-4">
                <i class="bi bi-cart-x display-1 text-muted opacity-25"></i>
            </div>
            <h3 class="fw-bold">Giỏ hàng đang trống</h3>
            <p class="text-muted mx-auto" style="max-width:400px;">Hãy khám phá bộ sưu tập của chúng tôi và chọn cho mình những sản phẩm ưng ý nhất.</p>
            <a href="~/Product" class="btn btn-primary rounded-pill px-5 py-3 mt-4 fw-bold shadow-sm">
                <i class="bi bi-bag-heart me-2"></i> Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <div class="row g-5">
            <!-- Cart Items List -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light bg-opacity-50">
                                <tr>
                                    <th class="ps-4 py-3" style="width: 50px;">
                                        <div class="form-check">
                                            <input class="form-check-input shadow-none cursor-pointer" type="checkbox" id="selectAllCart" checked>
                                        </div>
                                    </th>
                                    <th class="py-3 fs-8 fw-bold text-muted uppercase tracking-wider">Sản phẩm</th>
                                    <th class="py-3 text-center fs-8 fw-bold text-muted uppercase tracking-wider">Đơn giá</th>
                                    <th class="py-3 text-center fs-8 fw-bold text-muted uppercase tracking-wider">Số lượng</th>
                                    <th class="py-3 text-end fs-8 fw-bold text-muted uppercase tracking-wider pe-4">Thành tiền</th>
                                    <th class="py-3" style="width: 60px;"></th>
                                </tr>
                            </thead>
                            <tbody id="cart-items" class="border-top-0">
                                @foreach (var item in Model)
                                {
                                    <tr data-id="@item.ProductID">
                                        <td class="ps-4">
                                            <div class="form-check">
                                                <input class="form-check-input cart-item-check shadow-none cursor-pointer" type="checkbox" value="@item.ProductID" checked>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="rounded-3 overflow-hidden bg-light border p-1 border-opacity-10" style="width:72px;height:72px;flex-shrink:0;">
                                                    <img src="@(string.IsNullOrEmpty(item.Photo) ? "https://placehold.co/100x100/fff7ed/f97316?text=NP" : (item.Photo.StartsWith("http") ? item.Photo : $"/images/products/{item.Photo}"))"
                                                         class="w-100 h-100 object-fit-cover rounded-2" />
                                                </div>
                                                <div>
                                                    <h6 class="fw-bold fs-7 mb-1 text-dark">@item.ProductName</h6>
                                                    <span class="badge bg-light text-muted fw-normal">DVT: @item.Unit</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center fw-600 fs-7">@item.Price.ToString("N0")<small>đ</small></td>
                                        <td class="text-center">
                                            <div class="d-inline-flex align-items-center bg-light rounded-pill p-1">
                                                <button class="btn btn-sm btn-white rounded-circle shadow-none py-0 px-2" onclick="updateQty(@item.ProductID, -1)"><i class="bi bi-dash"></i></button>
                                                <input type="text" class="form-control form-control-sm border-0 bg-transparent text-center fw-bold shadow-none" id="qty-@item.ProductID" value="@item.Quantity" readonly style="width: 40px;">
                                                <button class="btn btn-sm btn-white rounded-circle shadow-none py-0 px-2" onclick="updateQty(@item.ProductID, 1)"><i class="bi bi-plus"></i></button>
                                            </div>
                                        </td>
                                        <td class="text-end fw-bold text-primary fs-6 pe-4" id="subtotal-@item.ProductID">
                                            @item.TotalPrice.ToString("N0")<small>đ</small>
                                        </td>
                                        <td class="pe-4 text-end">
                                            <button onclick="removeItem(@item.ProductID)" class="btn btn-sm btn-outline-danger border-0 rounded-circle py-2">
                                                <i class="bi bi-trash3 fs-6"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="d-flex justify-content-end mt-3">
                     <button type="button" class="btn btn-link text-danger fs-7 fw-600 text-decoration-none" onclick="clearCartConfirm()">
                        <i class="bi bi-x-circle me-1"></i> Làm trống giỏ hàng
                    </button>
                </div>
            </div>

            <!-- Summary -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 sticky-top" style="top: 100px;">
                    <h5 class="fw-bold text-dark mb-4 pb-2 border-bottom">Tóm tắt đơn hàng</h5>
                    
                    <div class="d-flex flex-column gap-3 mb-4">
                        <div class="d-flex justify-content-between fs-7 text-muted">
                            <span>Tạm tính</span>
                            <span class="fw-bold text-dark" id="cart-total-summary">@total.ToString("N0") đ</span>
                        </div>
                        <div class="d-flex justify-content-between fs-7 text-muted">
                            <span>Vận chuyển</span>
                            <span class="text-success fw-bold">Miễn phí</span>
                        </div>
                        <div class="d-flex justify-content-between fs-7 text-muted">
                            <span>Giảm giá</span>
                            <span class="fw-bold text-dark">0 đ</span>
                        </div>
                    </div>

                    <div class="bg-light rounded-3 p-3 mb-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold fs-7 text-dark">Tổng cộng:</span>
                            <h3 class="fw-900 text-primary mb-0"><span id="cart-total-display">@total.ToString("N0")</span><small class="fs-6 fw-bold ms-1">đ</small></h3>
                        </div>
                    </div>

                    <a href="~/Cart/Checkout" class="btn btn-primary w-100 py-3 rounded-pill fw-bold fs-6 shadow-sm">
                        Tiến hành thanh toán <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                    
                    <div class="text-center mt-4">
                        <p class="fs-8 text-muted mb-0"><i class="bi bi-shield-lock me-1"></i> Giao dịch của bạn luôn được bảo mật</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function recalculateTotal() {
            var total = 0;
            var checkboxes = document.querySelectorAll('.cart-item-check');
            var allChecked = true;
            var hasItems = checkboxes.length > 0;

            checkboxes.forEach(function(cb) {
                if (cb.checked) {
                    var id = cb.value;
                    var subtotalElement = document.getElementById('subtotal-' + id);
                    if (subtotalElement) {
                        var text = subtotalElement.innerText.replace('đ', '').replace(/\./g, '').replace(/,/g, '').trim();
                        total += parseInt(text) || 0;
                    }
                } else {
                    allChecked = false;
                }
            });

            var selectAllCb = document.getElementById('selectAllCart');
            if (selectAllCb) {
                selectAllCb.checked = hasItems ? allChecked : false;
            }

            var formattedTotal = total.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".");
            
            var summaryEl = document.getElementById('cart-total-summary');
            if (summaryEl) summaryEl.textContent = formattedTotal + ' đ';
            
            var displayEl = document.getElementById('cart-total-display');
            if (displayEl) displayEl.textContent = formattedTotal;
        }

        document.addEventListener('DOMContentLoaded', function() {
            var selectAll = document.getElementById('selectAllCart');
            if (selectAll) {
                selectAll.addEventListener('change', function(e) {
                    var isChecked = e.target.checked;
                    document.querySelectorAll('.cart-item-check').forEach(function(cb) {
                        cb.checked = isChecked;
                    });
                    recalculateTotal();
                });
            }

            document.querySelectorAll('.cart-item-check').forEach(function(cb) {
                cb.addEventListener('change', recalculateTotal);
            });
            
            recalculateTotal();
            
            var checkoutBtn = document.querySelector('a[href*="Checkout"]');
            if (checkoutBtn) {
                checkoutBtn.addEventListener('click', function(e) {
                    var checkedIds = Array.from(document.querySelectorAll('.cart-item-check:checked')).map(cb => cb.value);
                    if (checkedIds.length === 0) {
                        e.preventDefault();
                        showAlertModal({ title: 'Thông báo', message: 'Vui lòng chọn ít nhất 1 sản phẩm để thanh toán!' });
                    } else {
                        document.cookie = "selectedCartItems=" + checkedIds.join(',') + "; path=/;";
                    }
                });
            }
        });

        function clearCartConfirm() {
            showConfirmModal({
                title: 'Xác nhận',
                message: 'Bạn muốn làm trống giỏ hàng?',
                confirmText: 'Làm trống',
                cancelText: 'Quay lại'
            }).then(function (ok) {
                if (ok) {
                    fetch('/Cart/EmptyBasket', { method: 'POST' }).then(() => location.reload());
                }
            });
        }

        function updateQty(productId, delta) {
            var input = document.getElementById('qty-' + productId);
            if (!input) return;
            var currentCount = parseInt(input.value) + delta;
            if (currentCount < 1) return;

            fetch('/Cart/ModifyQuantity', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'productId=' + productId + '&count=' + currentCount
            })
            .then(function(res) { return res.json(); })
            .then(function(data) {
                if (data.success) {
                    input.value = currentCount;
                    document.getElementById('subtotal-' + productId).innerHTML = data.subtotal + '<small>đ</small>';
                    recalculateTotal();
                    updateBadge(data.itemCountTotal);
                }
            });
        }

        function removeItem(productId) {
            showConfirmModal({
                title: 'Xác nhận xóa',
                message: 'Bạn muốn loại bỏ sản phẩm này khỏi giỏ hàng?',
                confirmText: 'Đồng ý',
                cancelText: 'Hủy'
            }).then(function (ok) {
                if (!ok) return;
                fetch('/Cart/DeleteEntry', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'productId=' + productId
                })
                .then(function(res) { return res.json(); })
                .then(function(data) {
                    if (data.success) {
                        var targetRow = document.querySelector('tr[data-id="' + productId + '"]');
                        if (targetRow) targetRow.remove();
                        recalculateTotal();
                        updateBadge(data.itemCount);
                        if (data.itemCount === 0) location.reload();
                    }
                });
            });
        }
    </script>
}

<style>
    .fw-900 { font-weight: 900; }
    .fs-8 { font-size: 0.75rem; }
    .uppercase { text-transform: uppercase; }
    .tracking-wider { letter-spacing: 0.05em; }
    .transition-all { transition: all 0.2s ease; }
    .hover-bg-light:hover { background-color: #f8fafc; }
    .object-fit-cover { object-fit: cover; }
    .cursor-pointer { cursor: pointer; }
    .btn-white { background: #fff; border: 1px solid #e2e8f0; }
    .btn-white:hover { background: #f8fafc; }
</style>
