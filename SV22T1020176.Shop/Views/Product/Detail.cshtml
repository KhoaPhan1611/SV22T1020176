@model SV22T1020176.Models.Catalog.Product
@using SV22T1020176.Models.Partner
@using SV22T1020176.Models.Catalog
@{
    ViewData["Title"] = Model.ProductName;
    var extraPhotos = ViewBag.Photos as IList<ProductPhoto> ?? new List<ProductPhoto>();
    var attrs = ViewBag.Attributes as IList<ProductAttribute>;
    var supplier = ViewBag.Supplier as Supplier;
    var category = ViewBag.Category as Category;

    string MainUrl()
    {
        if (string.IsNullOrEmpty(Model.Photo)) return "https://placehold.co/600x600/fff7ed/f97316?text=" + Uri.EscapeDataString(Model.ProductName);
        if (Model.Photo.StartsWith("http")) return Model.Photo;
        return Url.Content("~/images/products/" + Model.Photo)!;
    }

    string ThumbUrl(string photo)
    {
        if (string.IsNullOrEmpty(photo)) return "https://placehold.co/100x100/fff7ed/f97316?text=Image";
        if (photo.StartsWith("http")) return photo;
        return Url.Content("~/images/products/" + photo)!;
    }
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-5">
    <ol class="breadcrumb bg-transparent p-0 fs-7">
        <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Trang chủ</a></li>
        <li class="breadcrumb-item"><a href="/Product" class="text-decoration-none text-muted">Sản phẩm</a></li>
        <li class="breadcrumb-item active fw-bold text-dark" aria-current="page">@Model.ProductName</li>
    </ol>
</nav>

<div class="row g-5 animate-in">
    <!-- GALLERY (Left) -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm overflow-hidden mb-4 rounded-4">
            <div id="mainImageWrapper" class="position-relative overflow-hidden cursor-zoom-in" 
                 onmousemove="zoomImage(event)" onmouseleave="resetZoom()" style="aspect-ratio: 1/1; background: #fff;">
                <img id="mainProductImage" src="@MainUrl()" alt="@Model.ProductName" 
                     class="w-100 h-100 object-fit-contain transition-all" />
                
                @if (!Model.IsSelling)
                {
                    <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-50">
                        <span class="badge bg-danger px-4 py-2 fs-6 shadow-lg">NGỪNG BÁN</span>
                    </div>
                }
            </div>
        </div>

        @if (extraPhotos.Any(p => !p.IsHidden))
        {
            <div class="d-flex gap-3 overflow-auto pb-2 scrollbar-thin">
                <div class="thumb-item active border-primary border-2 border p-1 rounded-3 bg-white cursor-pointer transition-all" data-src="@MainUrl()" style="width: 80px; height: 80px; flex-shrink: 0;">
                    <img src="@MainUrl()" class="w-100 h-100 object-fit-cover rounded-2" alt="Thumb" />
                </div>
                @foreach (var photo in extraPhotos.Where(p => !p.IsHidden))
                {
                    var u = ThumbUrl(photo.Photo);
                    <div class="thumb-item border p-1 rounded-3 bg-white cursor-pointer transition-all hover-border-primary" data-src="@u" style="width: 80px; height: 80px; flex-shrink: 0;">
                        <img src="@u" class="w-100 h-100 object-fit-cover rounded-2" alt="Thumb" />
                    </div>
                }
            </div>
        }

        <!-- Description -->
        @if (!string.IsNullOrWhiteSpace(Model.ProductDescription))
        {
            <div class="card border-0 shadow-sm mt-5 rounded-4 overflow-hidden">
                <div class="card-header bg-white border-0 py-3 px-4 d-flex align-items-center gap-3">
                    <i class="bi bi-text-left text-primary fs-4"></i>
                    <h5 class="mb-0 fw-bold">Mô tả sản phẩm</h5>
                </div>
                <div class="card-body px-4 pb-4 pt-0">
                    <div class="fs-7 text-dark opacity-75 lh-lg" style="white-space: pre-line;">
                        @Model.ProductDescription
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- INFO (Right) -->
    <div class="col-lg-6">
        <div class="ps-lg-4">
            <!-- Header Info -->
            <div class="mb-4">
                <div class="d-flex align-items-center gap-2 mb-3">
                    @if (category != null)
                    {
                        <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill fw-bold">@category.CategoryName</span>
                    }
                    <span class="badge bg-light text-dark px-3 py-2 rounded-pill fw-600">DVT: @Model.Unit</span>
                </div>
                <h1 class="fw-800 text-dark display-6 mb-3">@Model.ProductName</h1>
                
                @if (supplier != null)
                {
                    <div class="d-flex align-items-center gap-2 text-muted fs-7">
                        <i class="bi bi-patch-check-fill text-info"></i>
                        <span>Cung cấp bởi: <strong class="text-dark">@supplier.SupplierName</strong></span>
                    </div>
                }
            </div>

            <!-- Price -->
            <div class="card bg-primary bg-opacity-5 border-0 p-4 rounded-4 mb-5">
                <div class="text-muted fs-8 fw-bold uppercase mb-1 tracking-wider">Giá bán hiện tại</div>
                <div class="d-flex align-items-baseline gap-2">
                    <h2 class="text-primary fw-900 display-4 mb-0">@Model.Price.ToString("N0")</h2>
                    <span class="text-primary fw-bold fs-4">₫</span>
                </div>
            </div>

            <!-- Actions -->
            @if (Model.IsSelling)
            {
                <div class="mb-5">
                    <div class="d-flex align-items-center gap-4 mb-4">
                        <span class="fw-bold text-dark fs-7">Số lượng:</span>
                        <div class="input-group" style="width: 140px;">
                            <button class="btn btn-outline-secondary border-0 bg-light rounded-start-pill" type="button" onclick="changeDetailQty(-1)"><i class="bi bi-dash-lg"></i></button>
                            <input type="text" class="form-control border-0 bg-light text-center fw-bold fs-6" id="detail-qty" value="1" readonly>
                            <button class="btn btn-outline-secondary border-0 bg-light rounded-end-pill" type="button" onclick="changeDetailQty(1)"><i class="bi bi-plus-lg"></i></button>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <button type="button" onclick="addToCart(@Model.ProductID, parseInt($('#detail-qty').val()) || 1)" 
                                    class="btn btn-outline-primary w-100 py-3 rounded-pill fw-bold fs-6">
                                <i class="bi bi-cart-plus me-2"></i> Thêm vào giỏ
                            </button>
                        </div>
                        <div class="col-sm-6">
                            <button type="button" onclick="document.cookie='selectedCartItems=@Model.ProductID; path=/'; window.location='/Cart/Checkout'" 
                                    class="btn btn-primary w-100 py-3 rounded-pill fw-bold fs-6 shadow-sm">
                                <i class="bi bi-lightning-charge-fill me-2"></i> Mua ngay
                            </button>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning rounded-4 border-0 shadow-sm d-flex align-items-center gap-3 py-4 px-4 mb-5">
                    <i class="bi bi-exclamation-triangle-fill fs-3"></i>
                    <div>
                        <h6 class="mb-1 fw-bold">Sản phẩm tạm hết hàng</h6>
                        <p class="mb-0 small opacity-75">Sản phẩm này hiện đang ngừng kinh doanh hoặc đã hết hàng. Vui lòng quay lại sau.</p>
                    </div>
                </div>
            }

            <!-- Specifications Table -->
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mt-4">
                <div class="card-header bg-white border-0 py-3 px-4 d-flex align-items-center gap-3">
                    <i class="bi bi-info-circle text-primary fs-4"></i>
                    <h5 class="mb-0 fw-bold">Thông tin chi tiết</h5>
                </div>
                <div class="card-body p-0">
                    @if (attrs != null && attrs.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-borderless mb-0">
                                <tbody>
                                    @foreach (var attr in attrs.OrderBy(a => a.DisplayOrder))
                                    {
                                        <tr>
                                            <td class="ps-4 py-3 fw-600 text-muted fs-7" style="width: 40%">@attr.AttributeName</td>
                                            <td class="pe-4 py-3 text-dark fw-500 fs-7">@attr.AttributeValue</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="py-5 text-center text-muted">
                            <i class="bi bi-info-circle fs-2 opacity-25 mb-2 d-block"></i>
                            <span class="fs-7">Chưa có thông số chi tiết</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeDetailQty(delta) {
            var input = $('#detail-qty');
            var qty = parseInt(input.val()) + delta;
            if (qty < 1) qty = 1;
            input.val(qty);
        }

        $(function () {
            $('.thumb-item').on('click', function () {
                var src = $(this).data('src');
                if (!src) return;
                $('#mainProductImage').attr('src', src).css('transform', 'scale(1)');
                $('.thumb-item').removeClass('active border-primary border-2').addClass('border-1 border-muted opacity-75');
                $(this).removeClass('border-muted opacity-75').addClass('active border-primary border-2');
            });
        });

        function zoomImage(e) {
            var img = $('#mainProductImage');
            var wrapper = $('#mainImageWrapper');
            // Use native offsetX/Y for precision
            var x = (e.offsetX || e.pageX - $(wrapper).offset().left) / wrapper.width();
            var y = (e.offsetY || e.pageY - $(wrapper).offset().top) / wrapper.height();
            img.css({
                'transform': 'scale(2)',
                'transform-origin': (x * 100) + '% ' + (y * 100) + '%'
            });
        }

        function resetZoom() {
            $('#mainProductImage').css('transform', 'scale(1)');
        }
    </script>
    <style>
        .cursor-zoom-in { cursor: zoom-in; }
        .hover-border-primary:hover { border-color: var(--cui-primary) !important; }
        .fw-900 { font-weight: 900; }
        .transition-all { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        .scrollbar-thin::-webkit-scrollbar { height: 4px; }
        .scrollbar-thin::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 4px; }
    </style>
}
